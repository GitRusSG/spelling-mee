{
  "expo": {
    "name": "Spelling Mee",
    "slug": "spelling-mee",
    "scheme": "spelling-mee",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spellingmee.app"
    },
    "android": {
      "package": "com.spellingmee.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "baseUrl": "/spelling-mee"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
